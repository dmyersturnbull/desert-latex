# Build directly to PDF with LuaLaTeX.
$pdf_mode = 4;

# LuaLaTeX command:
#   -halt-on-error   => stop on the first error
#   -file-line-error => file:line style diagnostics
#   -synctex=1       => enable source <-> PDF sync
#   %O               => latexmk-supplied options
#   %S               => source file
$lualatex = 'lualatex -halt-on-error -file-line-error -synctex=1 %O %S';

# Cap reruns needed to resolve cross-references, index inclusion, etc.
$max_repeat = 5;

# Nomenclature:
#   .nlo -> .nls using makeindex + nomencl.ist
add_cus_dep('nlo', 'nls', 0, 'make_nomenclature');
sub make_nomenclature {
    my ($base) = @_;
    return system("makeindex \"$base.nlo\" -s nomencl.ist -o \"$base.nls\" -t \"$base.nlg\"");
}

# Mark generated files to allow `latexmk -c` to remove them.
push @generated_exts, 'nls';
$clean_ext .= ' nlo nls nlg ilg ind idx';
